## API Configuration
NEXT_PUBLIC_API_BASE_URL=http://localhost:3001/api

# Optional
## Environment
NEXT_PUBLIC_APP_ENV=development
NEXT_PUBLIC_APP_GIT_SHORT_SHA=$(git rev-parse --short=7 HEAD)
PORT=3000
CI=false

## Analytics & Monitoring
