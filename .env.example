NEXT_PUBLIC_POSTHOG_UI_HOST=https://us.posthog.com  # PostHog app UI host (for toolbar)

# Umami
NEXT_PUBLIC_UMAMI_WEBSITE_ID=''
UMAMI_SCRIPT_URL=''
UMAMI_API_URL=''
